# Supabase Environment Variables
# Copy this file to .env.local and fill in your values

# Required - Get from Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Required for Admin - Get from Supabase Dashboard → Settings → API
# Use the service_role key (not anon key) for admin operations
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required - Set any password you want for admin access
NEXT_PUBLIC_ADMIN_PASSWORD=your-admin-password